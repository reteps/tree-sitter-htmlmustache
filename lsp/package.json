{
  "name": "htmlmustache-lsp",
  "displayName": "HTML Mustache Language Support",
  "description": "Language server for HTML with Mustache template syntax",
  "version": "0.0.34",
  "publisher": "reteps",
  "private": true,
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/reteps/tree-sitter-htmlmustache"
  },
  "homepage": "https://github.com/reteps/tree-sitter-htmlmustache#readme",
  "bugs": {
    "url": "https://github.com/reteps/tree-sitter-htmlmustache/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:htmlmustache"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "htmlmustache",
        "aliases": [
          "HTML Mustache",
          "Mustache",
          "Handlebars"
        ],
        "extensions": [
          ".mustache",
          ".hbs",
          ".handlebars"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mustache.svg",
          "dark": "./icons/mustache.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "htmlmustache",
        "scopeName": "text.html.htmlmustache",
        "path": "./syntaxes/htmlmustache.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.css": "css"
        }
      }
    ],
    "configuration": {
      "type": "object",
      "title": "HTML Mustache",
      "properties": {
        "htmlmustache.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    },
    "semanticTokenTypes": [
      {
        "id": "tag",
        "description": "HTML/XML tag name"
      },
      {
        "id": "attributeName",
        "description": "HTML attribute name"
      },
      {
        "id": "attributeValue",
        "description": "HTML attribute value"
      },
      {
        "id": "delimiter",
        "description": "HTML tag delimiters like < > </ />"
      },
      {
        "id": "mustacheVariable",
        "description": "Mustache variable or section name"
      },
      {
        "id": "mustacheDelimiter",
        "description": "Mustache delimiters like {{ }} {{# {{/"
      },
      {
        "id": "constantLanguage",
        "superType": "keyword",
        "description": "Language constant (true, false, null)"
      },
      {
        "id": "operatorComparison",
        "superType": "operator",
        "description": "Comparison operator (==, !=, <, >)"
      },
      {
        "id": "operatorArithmetic",
        "superType": "operator",
        "description": "Arithmetic operator (+, -, *, /)"
      },
      {
        "id": "operatorLogical",
        "superType": "operator",
        "description": "Logical operator (&&, ||, !)"
      },
      {
        "id": "operatorAssignment",
        "superType": "operator",
        "description": "Assignment operator (=, +=, -=)"
      },
      {
        "id": "operatorBitwise",
        "superType": "operator",
        "description": "Bitwise operator (&, |, ^, ~)"
      },
      {
        "id": "operatorWord",
        "superType": "operator",
        "description": "Word operator (and, or, not, in)"
      },
      {
        "id": "keywordControl",
        "superType": "keyword",
        "description": "Control flow keyword (if, else, for, while)"
      },
      {
        "id": "storageType",
        "superType": "keyword",
        "description": "Storage type keyword (int, float, class, def)"
      },
      {
        "id": "supportFunction",
        "superType": "function",
        "description": "Built-in or library function"
      },
      {
        "id": "supportType",
        "superType": "type",
        "description": "Built-in or library type"
      },
      {
        "id": "variableLanguage",
        "superType": "variable",
        "description": "Language variable (self, this, super)"
      },
      {
        "id": "punctuation",
        "description": "Punctuation characters"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "c",
        "description": "C language"
      },
      {
        "id": "cpp",
        "description": "C++ language"
      },
      {
        "id": "python",
        "description": "Python language"
      },
      {
        "id": "javascript",
        "description": "JavaScript language"
      },
      {
        "id": "typescript",
        "description": "TypeScript language"
      },
      {
        "id": "java",
        "description": "Java language"
      },
      {
        "id": "go",
        "description": "Go language"
      },
      {
        "id": "rust",
        "description": "Rust language"
      },
      {
        "id": "ruby",
        "description": "Ruby language"
      },
      {
        "id": "css",
        "description": "CSS language"
      },
      {
        "id": "html",
        "description": "HTML language"
      },
      {
        "id": "sql",
        "description": "SQL language"
      },
      {
        "id": "php",
        "description": "PHP language"
      },
      {
        "id": "csharp",
        "description": "C# language"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "htmlmustache",
        "scopes": {
          "tag": [
            "entity.name.tag.html"
          ],
          "attributeName": [
            "entity.other.attribute-name.html"
          ],
          "attributeValue": [
            "string.quoted.double.html"
          ],
          "delimiter": [
            "punctuation.definition.tag.begin.html"
          ],
          "mustacheVariable": [
            "variable.other.constant"
          ],
          "mustacheDelimiter": [
            "keyword.control.handlebars"
          ],
          "comment": [
            "comment"
          ],
          "string": [
            "string"
          ],
          "regexp": [
            "string.regexp"
          ],
          "number": [
            "constant.numeric"
          ],
          "constantLanguage": [
            "constant.language"
          ],
          "operatorComparison": [
            "keyword.operator.comparison"
          ],
          "operatorArithmetic": [
            "keyword.operator.arithmetic"
          ],
          "operatorLogical": [
            "keyword.operator.logical"
          ],
          "operatorAssignment": [
            "keyword.operator.assignment"
          ],
          "operatorBitwise": [
            "keyword.operator.bitwise"
          ],
          "operatorWord": [
            "keyword.operator.word"
          ],
          "operator": [
            "keyword.operator"
          ],
          "keywordControl": [
            "keyword.control"
          ],
          "keyword": [
            "keyword"
          ],
          "storageType": [
            "storage.type"
          ],
          "modifier": [
            "storage.modifier"
          ],
          "function": [
            "entity.name.function"
          ],
          "functionCall": [
            "meta.function-call.generic",
            "entity.name.function"
          ],
          "supportFunction": [
            "support.function"
          ],
          "type": [
            "entity.name.type"
          ],
          "supportType": [
            "support.type"
          ],
          "property": [
            "meta.attribute",
            "variable.other.property"
          ],
          "indexedName": [
            "meta.indexed-name",
            "variable.other"
          ],
          "parameter": [
            "variable.parameter"
          ],
          "variableLanguage": [
            "variable.language"
          ],
          "variable": [
            "variable"
          ],
          "punctuation": [
            "punctuation"
          ],
          "markupHeading": [
            "markup.heading"
          ],
          "markupBold": [
            "markup.bold"
          ],
          "markupItalic": [
            "markup.italic"
          ],
          "markupUnderline": [
            "markup.underline"
          ],
          "markupStrikethrough": [
            "markup.strikethrough"
          ],
          "markupInlineCode": [
            "markup.inline.raw"
          ],
          "markupFencedCode": [
            "markup.fenced_code"
          ],
          "markupLink": [
            "markup.underline.link"
          ],
          "markupList": [
            "markup.list"
          ],
          "markupQuote": [
            "markup.quote"
          ],
          "markupRaw": [
            "markup.raw"
          ],
          "markup": [
            "markup"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:production",
    "copy-wasm": "cp ../tree-sitter-htmlmustache.wasm ./tree-sitter-htmlmustache.wasm && cp server/node_modules/web-tree-sitter/web-tree-sitter.wasm ./server/out/ && cp node_modules/.pnpm/@one-ini+wasm@0.2.0/node_modules/@one-ini/wasm/one_ini_bg.wasm ./server/out/ && cp server/node_modules/vscode-oniguruma/release/onig.wasm ./server/out/",
    "clean": "rm -rf server/out client/out && mkdir -p server/out client/out",
    "build": "pnpm run clean && node esbuild.mjs && pnpm run copy-wasm",
    "build:production": "pnpm run clean && node esbuild.mjs --production && pnpm run copy-wasm",
    "typecheck": "pnpm --filter htmlmustache-lsp-client exec tsc --noEmit && pnpm --filter htmlmustache-lsp-server exec tsc --noEmit",
    "watch": "pnpm run prebuild && node esbuild.mjs --watch",
    "lint": "eslint ./client/src ./server/src",
    "test": "pnpm --filter htmlmustache-lsp-server run test",
    "test:watch": "pnpm --filter htmlmustache-lsp-server run test:watch",
    "test:e2e": "pnpm run build && node ./client/out/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.14.0",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.14.0"
  }
}
