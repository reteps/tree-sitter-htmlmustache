{
  "name": "@reteps/tree-sitter-htmlmustache",
  "version": "0.4.0",
  "description": "HTML with Mustache/Handlebars template syntax grammar for tree-sitter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reteps/tree-sitter-htmlmustache.git"
  },
  "license": "MIT",
  "author": {
    "name": "Peter Stenger"
  },
  "main": "bindings/node",
  "bin": {
    "htmlmustache": "cli/out/main.js"
  },
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "html",
    "mustache",
    "handlebars"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm",
    "cli/out/*"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "editorconfig": "^3.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "web-tree-sitter": "^0.26.5"
  },
  "peerDependencies": {
    "node-addon-api": "^8.2.2",
    "node-gyp-build": "^4.8.2",
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "node-addon-api": {
      "optional": true
    },
    "node-gyp-build": {
      "optional": true
    },
    "tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.14.0",
    "eslint-config-treesitter": "^1.0.2",
    "prebuildify": "^6.0.1",
    "prettier": "^3.8.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter",
      "tree-sitter-cli"
    ]
  },
  "scripts": {
    "install": "node-gyp-build || exit 0",
    "build": "tree-sitter build --wasm",
    "prepack": "tree-sitter build --wasm && node cli/esbuild.mjs",
    "build:cli": "node cli/esbuild.mjs",
    "check": "node cli/out/check.js check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "tree-sitter test && node --test bindings/node/*_test.js",
    "test:cli": "vitest run --config cli/vitest.config.ts"
  }
}
